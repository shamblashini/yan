# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and must never be committed.

# PostgreSQL password for the yan database user.
# Use a strong random string — e.g: openssl rand -hex 32
POSTGRES_PASSWORD=change_me

# Bearer token that all clients must send in the Authorization header.
# Use a strong random string — e.g: openssl rand -hex 32
AUTH_TOKEN=change_me

# Host port to expose the server on (default: 3000).
# LISTEN_PORT=3000

# Log verbosity (default shown).
# RUST_LOG=yan_server=info,tower_http=warn
